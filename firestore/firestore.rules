rules_version = '2';

// Studio Console Firestore rules — targets the DEDICATED `studio-console`
// named database on opsagent-prod, NOT `(default)`. Other opsagent-prod apps
// (lead-pipeline, trainer, etc.) cannot affect or be affected by this file.
// Cutover: 2026-05-29 — see Trello card wuCC3pQs and runbook card GXrvHmnG.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/studioConsoleAllowlist/$(userEmail()))
        && get(/databases/$(database)/documents/studioConsoleAllowlist/$(userEmail())).data.role == 'admin';
    }

    // Allowlist registry — admins manage via the proxy; allowlisted users can
    // read their own doc to resolve their role at sign-in.
    match /studioConsoleAllowlist/{email} {
      allow read:  if isAdmin() || (signedIn() && email == userEmail());
      allow write: if false;  // mutations flow through proxy /admin/users (Admin SDK bypasses rules)
    }

    // Per-user generation history — owner read, admin read-all, proxy-only write.
    match /studioConsoleGenerations/{uid}/items/{generationId} {
      allow read:  if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow write: if false;  // proxy-only via Admin SDK
    }

    // Per-user usage counters — owner + admin read, proxy-only write.
    match /studioConsoleUsage/{uid} {
      allow read:  if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow write: if false;  // proxy-only via Admin SDK
    }

    // Catch-all deny — safe to keep on a dedicated DB.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
